{
    "name": "schema-hub",
    "version": "0.0.0-dev",
    "type": "module",
    "scripts": {
        "compile": "tsc --build",
        "eslint": "eslint . .github --cache --cache-location './target/.eslintcache' --cache-strategy content --max-warnings 0",
        "eslint:fix": "npm run eslint -- --fix",
        "lint": "npm run eslint",
        "lint:fix": "npm run eslint:fix",
        "test": "npm run test:unit:with-coverage && npm run test:types && npm run test:integration",
        "pretest:integration": "tsc -b integration-tests/tsconfig.json",
        "test:integration": "mt target/build/integration-tests",
        "test:types": "tstyche",
        "pretest:unit": "tsc -b source/tsconfig.unit-tests.json",
        "test:unit": "mt target/build/source",
        "test:unit:with-coverage": "c8 npm run test:unit"
    },
    "author": "Mathias Schreck <schreck.mathias@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enormora/schema-hub.git"
    },
    "dependencies": {
        "graphql": "17.0.1",
        "ky": "2.0.2",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@enormora/eslint-config-base": "0.0.43",
        "@enormora/eslint-config-node": "0.0.34",
        "@enormora/eslint-config-typescript": "0.0.50",
        "@packtory/cli": "0.0.46",
        "@sondr3/minitest": "0.1.2",
        "@types/common-tags": "1.8.4",
        "@types/node": "24.13.2",
        "@types/sinon": "21.0.1",
        "c8": "11.0.0",
        "common-tags": "1.8.2",
        "eslint": "10.5.0",
        "sinon": "22.0.0",
        "tstyche": "7.2.1",
        "typescript": "6.0.3",
        "zod": "4.4.3"
    },
    "engines": {
        "node": "^24 || ^26"
    },
    "peerDependencies": {
        "zod": "^4.0.5"
    },
    "overrides": {
        "yargs": "18.0.0"
    }
}
